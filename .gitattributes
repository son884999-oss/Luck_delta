# 바이너리 — 줄바꿈(CRLF) 변환 금지(손상 방지)
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.mp3 binary
*.wav binary
*.pdf binary

# 소스는 LF로 정규화(혼선 방지)
*.js   text eol=lf
*.jsx  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf
