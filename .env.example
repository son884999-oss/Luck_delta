# ================================================================
# 천문 — 환경변수 예시 (.env 로 복사해서 값 채우기)
#   cp .env.example .env
# ⚠️ VITE_ 접두사 변수는 빌드 시 클라이언트 번들에 그대로 포함됩니다.
#    (브라우저에서 누구나 볼 수 있음) → 도메인/사용량 제한이 가능한 키만 쓰세요.
# ================================================================

# ── AI (Gemini) ──────────────────────────────────────────────
# [운영 권장] 서버 전용 키만 설정 → 앱이 /api/gemini 프록시로 호출(키가 번들에 안 박힘).
#   · Vercel 환경변수에 GEMINI_API_KEY만 두고, VITE_GEMINI_API_KEY는 비워 둘 것.
#   · scripts/gen-report.mjs 등 Node 스크립트도 이 키를 사용.
GEMINI_API_KEY=
# [개발 전용] 로컬에서 프록시 없이 직접 호출하고 싶을 때만 채움.
#   ⚠️ 값이 있으면 빌드 시 번들에 그대로 노출됨 → 운영 배포엔 절대 두지 말 것.
VITE_GEMINI_API_KEY=

# ── 카카오 (식탁: 주변 식당/이미지 검색) ─────────────────────
# REST 키는 서버리스 함수(api/nearby.js·food-image.js)에서만 사용 — 서버 전용 권장
KAKAO_REST_KEY=
# (Vercel은 함수에 VITE_ 변수도 노출하므로 폴백으로 허용되지만, 노출 위험 있음)
VITE_KAKAO_REST_KEY=
# 카카오 지도 JS SDK (브라우저) — 콘솔에서 도메인 등록 필수
VITE_KAKAO_JS_KEY=

# ── 이메일 발송 (Resend · 서버리스) ──────────────────────────
RESEND_API_KEY=

# ── API 베이스 URL (선택) ────────────────────────────────────
# 비우면 동일 출처(/api)를 사용
VITE_API_BASE=

# ── 개발용 스크립트 전용 (메일/스크린샷) ─────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_PORT=8025
SHOTS_URL=http://localhost:5173
# 로컬 OG 렌더에 쓸 크롬 실행 파일 경로(선택)
LOCAL_CHROME=
